---
import KBLayout from '../../layouts/KBLayout.astro';
import { getCollection } from 'astro:content';
import { prettifyName } from '../../lib/kb';

export const prerender = true;

const allDocs = await getCollection('docs');
const recent = allDocs
  .filter(d => !d.data.draft)
  .slice(0, 15)
  .map(d => {
    const id = d.id;
    const slug = id.replace(/\.md$/, '');
    const parts = slug.split('/');
    return {
      slug,
      title: d.data.title || prettifyName(parts[parts.length - 1]),
      purpose: parts[0],
    };
  });
---
<KBLayout title="Knowledge Base">
  <h1 class="kb-index-title">Knowledge Base</h1>

  <h2 class="kb-index-section">Recent Articles</h2>
  <div class="kb-index-list">
    {recent.map((doc, i) => (
      <a
        href={`/knowledge/${doc.slug}`}
        class="kb-index-item"
        style={i < recent.length - 1 ? 'border-bottom: 1px solid #f0f0f0;' : ''}
      >
        <span class="kb-index-item-title">{doc.title}</span>
        <span class="kb-index-item-purpose">{doc.purpose}</span>
      </a>
    ))}
  </div>
</KBLayout>

<style>
  .kb-index-title {
    font-family: 'Space Mono', monospace;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .kb-index-section {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #8b8b9e;
    margin-bottom: 12px;
  }

  .kb-index-list {
    background: white;
    border: 1px solid #e8e8e8;
  }

  .kb-index-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    text-decoration: none;
    color: #2d2d3a;
  }

  .kb-index-item:hover {
    background: rgba(96, 165, 250, 0.04);
  }

  .kb-index-item-title {
    font-size: 14px;
    flex: 1;
  }

  .kb-index-item-purpose {
    font-size: 11px;
    color: #8b8b9e;
  }
</style>
