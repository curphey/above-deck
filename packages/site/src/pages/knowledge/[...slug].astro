---
import KBLayout from '../../layouts/KBLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { prettifyName } from '../../lib/kb';

export const prerender = true;

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter(doc => !doc.data.draft)
    .map(doc => ({
      params: { slug: doc.id.replace(/\.md$/, '') },
      props: { doc },
    }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const slug = doc.id.replace(/\.md$/, '');
const parts = slug.split('/');
const title = doc.data.title || prettifyName(parts[parts.length - 1]);

// Reading time estimate
const wordCount = doc.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Breadcrumb parts
const breadcrumbs = parts.slice(0, -1).map((part, i) => ({
  label: prettifyName(part),
  path: parts.slice(0, i + 1).join('/'),
}));

const siteUrl = 'https://abovedeck.io';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: doc.data.summary || '',
  author: {
    '@type': 'Organization',
    name: 'Above Deck',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Above Deck',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/knowledge/${slug}`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Knowledge',
      item: `${siteUrl}/knowledge`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: `${siteUrl}/knowledge/${slug}`,
    },
  ],
};
---
<KBLayout title={title} description={doc.data.summary} currentSlug={slug}>
  <JsonLd schema={articleSchema} slot="head" />
  <JsonLd schema={breadcrumbSchema} slot="head" />

  <!-- Breadcrumbs -->
  <nav class="kb-breadcrumb">
    <a href="/knowledge" class="kb-breadcrumb-link">KB</a>
    {breadcrumbs.map(bc => (
      <span>
        <span class="kb-breadcrumb-sep">/</span>
        <span>{bc.label}</span>
      </span>
    ))}
  </nav>

  <!-- Article header -->
  <h1 class="kb-article-title">{title}</h1>

  {doc.data.summary && (
    <p class="kb-article-summary">{doc.data.summary}</p>
  )}

  <div class="kb-article-meta">
    <span>{readingTime} min read</span>
    <span>&middot;</span>
    <span>{parts[0]}</span>
  </div>

  <!-- Article content -->
  <article class="kb-article-body">
    <Content />
  </article>

  <div class="kb-back-link">
    <a href="/knowledge">&larr; Back to Knowledge Base</a>
  </div>
</KBLayout>

<style>
  .kb-breadcrumb {
    font-size: 12px;
    color: #8b8b9e;
    margin-bottom: 16px;
  }

  .kb-breadcrumb-link {
    color: #60a5fa;
    text-decoration: none;
  }

  .kb-breadcrumb-link:hover {
    text-decoration: underline;
  }

  .kb-breadcrumb-sep {
    margin: 0 6px;
  }

  .kb-article-title {
    font-family: 'Space Mono', monospace;
    font-size: 22px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .kb-article-summary {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .kb-article-meta {
    font-size: 12px;
    color: #8b8b9e;
    margin-bottom: 24px;
    display: flex;
    gap: 12px;
  }

  .kb-back-link {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid #e8e8e8;
  }

  .kb-back-link a {
    font-size: 13px;
    color: #60a5fa;
    text-decoration: none;
  }

  .kb-back-link a:hover {
    text-decoration: underline;
  }
</style>

<style is:global>
  .kb-article-body {
    font-size: 15px;
    line-height: 1.7;
    color: #2d2d3a;
    max-width: 780px;
  }

  .kb-article-body h1 {
    font-family: 'Space Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    margin-top: 32px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #e8e8e8;
  }

  .kb-article-body h2 {
    font-family: 'Space Mono', monospace;
    font-size: 17px;
    font-weight: 700;
    margin-top: 28px;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #e8e8e8;
  }

  .kb-article-body h3 {
    font-family: 'Space Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    margin-top: 20px;
    margin-bottom: 8px;
  }

  .kb-article-body p {
    margin-bottom: 14px;
  }

  .kb-article-body ul,
  .kb-article-body ol {
    margin-bottom: 14px;
    padding-left: 24px;
  }

  .kb-article-body li {
    margin-bottom: 4px;
  }

  .kb-article-body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
    font-size: 13px;
  }

  .kb-article-body th {
    text-align: left;
    padding: 6px 10px;
    border-bottom: 2px solid #e8e8e8;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    color: #8b8b9e;
  }

  .kb-article-body td {
    padding: 6px 10px;
    border-bottom: 1px solid #f0f0f0;
  }

  .kb-article-body code {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    background: rgba(0, 0, 0, 0.04);
    padding: 1px 4px;
    border-radius: 2px;
  }

  .kb-article-body pre {
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 14px;
    margin-bottom: 16px;
    overflow-x: auto;
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    line-height: 1.5;
  }

  .kb-article-body pre code {
    background: none;
    padding: 0;
    color: inherit;
  }

  .kb-article-body a {
    color: #60a5fa;
    text-decoration: none;
  }

  .kb-article-body a:hover {
    text-decoration: underline;
  }

  .kb-article-body blockquote {
    border-left: 3px solid rgba(0, 0, 0, 0.1);
    padding-left: 16px;
    margin: 0 0 14px;
    color: #6b7280;
    font-style: italic;
  }

  .kb-article-body strong {
    font-weight: 600;
  }

  .kb-article-body img {
    max-width: 100%;
    height: auto;
  }

  .kb-article-body hr {
    border: none;
    border-top: 1px solid #e8e8e8;
    margin: 24px 0;
  }
</style>
