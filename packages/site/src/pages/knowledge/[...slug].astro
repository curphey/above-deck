---
import KBLayout from '../../layouts/KBLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { KBEditor } from '../../components/knowledge/KBEditor';
import { getCollection, render } from 'astro:content';
import { prettifyName } from '../../lib/kb';

export const prerender = true;

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter(doc => !doc.data.draft)
    .map(doc => ({
      params: { slug: doc.id.replace(/\.md$/, '') },
      props: { doc },
    }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const slug = doc.id.replace(/\.md$/, '');
const parts = slug.split('/');
const title = doc.data.title || prettifyName(parts[parts.length - 1]);

// Reading time estimate
const wordCount = doc.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Breadcrumb parts
const breadcrumbs = parts.slice(0, -1).map((part, i) => ({
  label: prettifyName(part),
  path: parts.slice(0, i + 1).join('/'),
}));

const siteUrl = 'https://abovedeck.io';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: doc.data.summary || '',
  author: {
    '@type': 'Organization',
    name: 'Above Deck',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Above Deck',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/knowledge/${slug}`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Knowledge',
      item: `${siteUrl}/knowledge`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: `${siteUrl}/knowledge/${slug}`,
    },
  ],
};
---
<KBLayout title={title} description={doc.data.summary} currentSlug={slug}>
  <JsonLd schema={articleSchema} slot="head" />
  <JsonLd schema={breadcrumbSchema} slot="head" />

  <!-- Breadcrumbs -->
  <nav class="kb-breadcrumb">
    <a href="/knowledge" class="kb-breadcrumb-link">KB</a>
    {breadcrumbs.map(bc => (
      <span>
        <span class="kb-breadcrumb-sep">/</span>
        <span>{bc.label}</span>
      </span>
    ))}
  </nav>

  <!-- Article header -->
  <div class="kb-article-header">
    <h1 class="kb-article-title">{title}</h1>
    <KBEditor slug={slug} client:load />
  </div>

  {doc.data.summary && (
    <p class="kb-article-summary">{doc.data.summary}</p>
  )}

  <div class="kb-article-meta">
    <span>{readingTime} min read</span>
    <span>&middot;</span>
    <span>{parts[0]}</span>
  </div>

  <!-- Article content -->
  <article class="kb-article-body">
    <Content />
  </article>

  <div class="kb-back-link">
    <a href="/knowledge">&larr; Back to Knowledge Base</a>
  </div>
</KBLayout>

<style>
  .kb-breadcrumb {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #8b8b9e;
    margin-bottom: 20px;
    letter-spacing: 0.3px;
  }

  .kb-breadcrumb-link {
    color: #60a5fa;
    text-decoration: none;
  }

  .kb-breadcrumb-link:hover {
    text-decoration: underline;
  }

  .kb-breadcrumb-sep {
    margin: 0 6px;
    color: #c0c0c0;
  }

  .kb-article-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .kb-article-title {
    font-family: 'Space Mono', monospace;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
    color: #2d2d3a;
  }

  .kb-article-summary {
    font-size: 15px;
    color: #8b8b9e;
    line-height: 1.6;
    margin-bottom: 16px;
    max-width: 640px;
  }

  .kb-article-meta {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #8b8b9e;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e8e8e8;
    display: flex;
    gap: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .kb-back-link {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid #e8e8e8;
  }

  .kb-back-link a {
    font-size: 13px;
    color: #60a5fa;
    text-decoration: none;
    transition: color 0.15s;
  }

  .kb-back-link a:hover {
    text-decoration: underline;
  }

  @media (max-width: 767px) {
    .kb-article-title {
      font-size: 20px;
    }
  }
</style>

<style is:global>
  .kb-article-body {
    font-size: 15px;
    line-height: 1.75;
    color: #2d2d3a;
    max-width: 720px;
  }

  .kb-article-body h1 {
    font-family: 'Space Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    margin-top: 40px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid #e8e8e8;
    color: #2d2d3a;
  }

  .kb-article-body h2 {
    font-family: 'Space Mono', monospace;
    font-size: 17px;
    font-weight: 700;
    margin-top: 36px;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid #e8e8e8;
    color: #2d2d3a;
  }

  .kb-article-body h3 {
    font-family: 'Space Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    margin-top: 28px;
    margin-bottom: 8px;
    color: #2d2d3a;
  }

  .kb-article-body h4 {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    margin-top: 24px;
    margin-bottom: 8px;
    color: #2d2d3a;
  }

  .kb-article-body p {
    margin-bottom: 16px;
  }

  .kb-article-body ul,
  .kb-article-body ol {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .kb-article-body li {
    margin-bottom: 6px;
    line-height: 1.6;
  }

  .kb-article-body li > ul,
  .kb-article-body li > ol {
    margin-top: 6px;
    margin-bottom: 0;
  }

  .kb-article-body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
    font-size: 13px;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    overflow: hidden;
  }

  .kb-article-body th {
    text-align: left;
    padding: 8px 12px;
    border-bottom: 2px solid #e8e8e8;
    background: #fafaf8;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #8b8b9e;
  }

  .kb-article-body td {
    padding: 8px 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .kb-article-body tr:last-child td {
    border-bottom: none;
  }

  .kb-article-body code {
    font-family: 'Fira Code', monospace;
    font-size: 0.85em;
    background: rgba(0, 0, 0, 0.05);
    padding: 2px 5px;
    border-radius: 3px;
  }

  .kb-article-body pre {
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 16px 20px;
    margin-bottom: 20px;
    overflow-x: auto;
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    line-height: 1.5;
    border-radius: 4px;
  }

  .kb-article-body pre code {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .kb-article-body a {
    color: #60a5fa;
    text-decoration: none;
    transition: color 0.15s;
  }

  .kb-article-body a:hover {
    text-decoration: underline;
  }

  .kb-article-body blockquote {
    border-left: 3px solid #60a5fa;
    padding: 12px 16px;
    margin: 0 0 16px;
    background: rgba(96, 165, 250, 0.04);
    color: #4b5563;
    border-radius: 0 4px 4px 0;
  }

  .kb-article-body blockquote p:last-child {
    margin-bottom: 0;
  }

  .kb-article-body strong {
    font-weight: 600;
  }

  .kb-article-body img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .kb-article-body hr {
    border: none;
    border-top: 1px solid #e8e8e8;
    margin: 32px 0;
  }
</style>
