---
import { getCollection } from 'astro:content';
import { buildTree, prettifyName } from '../lib/kb';
import KBSidebar from '../components/knowledge/KBSidebar';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description = 'Research, guides, and documentation for the Above Deck project', currentSlug } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Build tree from docs collection
const allDocs = await getCollection('docs');
const articles = allDocs
  .filter(doc => !doc.data.draft)
  .map(doc => ({
    id: doc.id,
    slug: doc.id.replace(/\.md$/, ''),
    title: doc.data.title || prettifyName(doc.id.split('/').pop()?.replace(/\.md$/, '') || doc.id),
    summary: doc.data.summary,
  }));

const tree = buildTree(articles);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Above Deck Knowledge Base</title>
  <link rel="canonical" href={canonicalURL} />
  <meta name="theme-color" content="#1a1a2e" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <slot name="head" />
</head>
<body>
  <div class="kb-shell">
    <header class="kb-header">
      <div class="kb-header-left">
        <button class="kb-sidebar-toggle" id="kb-sidebar-toggle" aria-label="Toggle sidebar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
        <a href="/" class="kb-header-logo">ABOVE DECK</a>
      </div>
      <nav class="kb-header-nav">
        <a href="/">Home</a>
        <a href="/knowledge" class="active">Knowledge</a>
      </nav>
    </header>
    <div class="kb-main">
      <div class="kb-sidebar-backdrop" id="kb-sidebar-backdrop"></div>
      <KBSidebar tree={tree} currentSlug={currentSlug} client:load />
      <main class="kb-content">
        <slot />
      </main>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('kb-sidebar-toggle');
    const backdrop = document.getElementById('kb-sidebar-backdrop');
    const shell = document.querySelector('.kb-shell');

    function closeSidebar() {
      shell?.classList.remove('kb-sidebar-open');
    }

    toggle?.addEventListener('click', () => {
      shell?.classList.toggle('kb-sidebar-open');
    });

    backdrop?.addEventListener('click', closeSidebar);
  </script>
</body>
</html>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #f5f5f0;
    color: #2d2d3a;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .kb-shell {
    display: flex;
    flex-direction: column;
    height: 100vh;
  }

  .kb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    padding: 0 24px;
    background: white;
    border-bottom: 1px solid #e8e8e8;
    flex-shrink: 0;
  }

  .kb-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .kb-sidebar-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    background: white;
    color: #2d2d3a;
    cursor: pointer;
    padding: 0;
  }

  .kb-sidebar-toggle:hover {
    background: #f5f5f0;
  }

  .kb-header-logo {
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    font-weight: 700;
    color: #2d2d3a;
    letter-spacing: 1px;
    text-decoration: none;
  }

  .kb-header-nav {
    display: flex;
    gap: 24px;
  }

  .kb-header-nav a {
    font-size: 14px;
    color: #8b8b9e;
    text-decoration: none;
    transition: color 0.15s;
  }

  .kb-header-nav a:hover {
    color: #2d2d3a;
  }

  .kb-header-nav a.active {
    color: #2d2d3a;
    font-weight: 600;
  }

  .kb-main {
    display: flex;
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .kb-sidebar-backdrop {
    display: none;
  }

  .kb-content {
    flex: 1;
    overflow-y: auto;
    padding: 32px 40px;
  }

  /* ---- Responsive: mobile (<768px) ---- */
  @media (max-width: 767px) {
    .kb-sidebar-toggle {
      display: flex;
    }

    .kb-sidebar {
      position: fixed;
      top: 56px;
      left: 0;
      bottom: 0;
      z-index: 100;
      transform: translateX(-100%);
      transition: transform 0.2s ease;
    }

    .kb-sidebar-open .kb-sidebar {
      transform: translateX(0);
    }

    .kb-sidebar-backdrop {
      position: fixed;
      top: 56px;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 99;
      background: rgba(0, 0, 0, 0.3);
    }

    .kb-sidebar-open .kb-sidebar-backdrop {
      display: block;
    }

    .kb-content {
      padding: 24px 20px;
    }
  }
</style>
