---
import { getCollection } from 'astro:content';
import { buildTree, prettifyName } from '../lib/kb';
import KBSidebar from '../components/knowledge/KBSidebar';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description = 'Research, guides, and documentation for the Above Deck project', currentSlug } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Build tree from docs collection
const allDocs = await getCollection('docs');
const articles = allDocs
  .filter(doc => !doc.data.draft)
  .map(doc => ({
    id: doc.id,
    slug: doc.id.replace(/\.md$/, ''),
    title: doc.data.title || prettifyName(doc.id.split('/').pop()?.replace(/\.md$/, '') || doc.id),
    summary: doc.data.summary,
  }));

const tree = buildTree(articles);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Above Deck Knowledge Base</title>
  <link rel="canonical" href={canonicalURL} />
  <meta name="theme-color" content="#1a1a2e" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <slot name="head" />
</head>
<body>
  <div class="kb-shell">
    <header class="kb-header">
      <a href="/" class="kb-header-logo">ABOVE DECK</a>
      <nav class="kb-header-nav">
        <a href="/">Home</a>
        <a href="/knowledge" class="active">Knowledge</a>
      </nav>
    </header>
    <div class="kb-main">
      <KBSidebar tree={tree} currentSlug={currentSlug} client:load />
      <main class="kb-content">
        <slot />
      </main>
    </div>
  </div>
</body>
</html>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #f5f5f0;
    color: #2d2d3a;
  }

  .kb-shell {
    display: flex;
    flex-direction: column;
    height: 100vh;
  }

  .kb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    padding: 0 24px;
    background: white;
    border-bottom: 1px solid #e8e8e8;
    flex-shrink: 0;
  }

  .kb-header-logo {
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    font-weight: 700;
    color: #2d2d3a;
    letter-spacing: 1px;
    text-decoration: none;
  }

  .kb-header-nav {
    display: flex;
    gap: 24px;
  }

  .kb-header-nav a {
    font-size: 14px;
    color: #6b7280;
    text-decoration: none;
  }

  .kb-header-nav a.active {
    color: #2d2d3a;
    font-weight: 600;
  }

  .kb-main {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .kb-content {
    flex: 1;
    overflow-y: auto;
    padding: 24px 32px;
  }
</style>
