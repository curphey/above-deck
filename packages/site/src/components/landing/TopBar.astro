---
// TopBar.astro — Logo and instrument readings on the titanium frame
---
<div class="top-bar">
  <div class="top-bar-logo">Above Deck</div>
  <div class="top-bar-readings">
    <div class="reading accent"><span class="val">12.8V</span></div>
    <div class="reading"><span class="val">342W</span></div>
    <div class="reading"><span class="val" data-utc>14:23 UTC</span></div>
    <div class="reading">
      <span class="val" data-coords>50°09'N 005°04'W</span>
      <span class="live-badge" data-live-badge hidden>
        <span class="live-dot"></span>Live
      </span>
    </div>
  </div>
</div>

<style>
  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Fira Code', monospace;
    font-size: 0.55rem;
    font-weight: 500;
    color: #4ade80;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-left: 6px;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .live-badge[data-visible] {
    opacity: 1;
  }

  .live-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #4ade80;
    animation: live-pulse 2s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4); }
    50% { opacity: 0.5; box-shadow: 0 0 6px 2px rgba(74, 222, 128, 0.15); }
  }
</style>

<script>
  function formatCoord(decimal: number, isLat: boolean): string {
    const dir = isLat ? (decimal >= 0 ? 'N' : 'S') : (decimal >= 0 ? 'E' : 'W');
    const abs = Math.abs(decimal);
    const deg = Math.floor(abs);
    const min = ((abs - deg) * 60).toFixed(2);
    const padMin = min.padStart(5, '0');
    return `${String(deg).padStart(isLat ? 2 : 3, '0')}°${padMin}'${dir}`;
  }

  function updateUTC() {
    const el = document.querySelector('[data-utc]');
    if (!el) return;
    const now = new Date();
    const h = String(now.getUTCHours()).padStart(2, '0');
    const m = String(now.getUTCMinutes()).padStart(2, '0');
    el.textContent = `${h}:${m} UTC`;
  }

  function initGeolocation() {
    if (!('geolocation' in navigator)) return;

    const coordsEl = document.querySelector('[data-coords]') as HTMLElement | null;
    const badgeEl = document.querySelector('[data-live-badge]') as HTMLElement | null;
    if (!coordsEl || !badgeEl) return;

    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const lat = formatCoord(pos.coords.latitude, true);
        const lon = formatCoord(pos.coords.longitude, false);
        coordsEl.textContent = `${lat} ${lon}`;
        badgeEl.hidden = false;
        requestAnimationFrame(() => badgeEl.setAttribute('data-visible', ''));

        // Keep updating
        navigator.geolocation.watchPosition(
          (p) => {
            const la = formatCoord(p.coords.latitude, true);
            const lo = formatCoord(p.coords.longitude, false);
            coordsEl.textContent = `${la} ${lo}`;
          },
          () => {},
          { enableHighAccuracy: false, maximumAge: 30000 }
        );
      },
      () => {
        // Permission denied or error — keep default coords, no badge
      },
      { enableHighAccuracy: false, timeout: 5000, maximumAge: 60000 }
    );
  }

  // Update UTC clock every 10 seconds
  updateUTC();
  setInterval(updateUTC, 10000);

  // Request geolocation
  initGeolocation();
</script>
