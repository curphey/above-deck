---
// WidgetLog.astro — Ship's log / news entries widget
---
<div class="widget">
  <div class="widget-head">
    <span class="widget-label">Ship's Log</span>
    <span class="widget-badge">3 new</span>
  </div>
  <div class="widget-body">
    <div class="log-entries">
      <div class="log-entry">
        <div class="log-tag">Project Update</div>
        <div class="log-title">Solar planner v0.1 — equipment-first design</div>
        <div class="log-date">Mar 12, 2026</div>
      </div>
      <div class="log-entry">
        <div class="log-tag">Community</div>
        <div class="log-title">What instruments does your cat run?</div>
        <div class="log-date">Mar 10, 2026</div>
      </div>
      <div class="log-entry">
        <div class="log-tag">Roadmap</div>
        <div class="log-title">Passage planning: tidal gates for the Channel</div>
        <div class="log-date">Mar 8, 2026</div>
      </div>
    </div>
  </div>
</div>
