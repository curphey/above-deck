---
// ScreenVHF.astro — VHF Radio Simulator placeholder screen
---
<div class="screen solar-screen" id="screen-vhf">
  <div class="schematic-header">
    <div>
      <div class="schematic-title">VHF Radio</div>
      <div class="schematic-subtitle">AI-powered radio practice for RYA exam prep</div>
    </div>
    <button class="back-btn" onclick="window.showScreen('home')">← Home</button>
  </div>

  <div class="vhf-placeholder">
    <div class="vhf-placeholder-content">
      <div class="vhf-radio-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 18v-6" /><path d="M8 18v-1" /><path d="M16 18v-1" />
          <rect x="5" y="18" width="14" height="4" rx="1" />
          <path d="M12 12a4 4 0 0 0 -4 -4" /><path d="M12 12a4 4 0 0 1 4 -4" />
          <path d="M12 12a8 8 0 0 0 -8 -8" /><path d="M12 12a8 8 0 0 1 8 -8" />
        </svg>
      </div>
      <div class="vhf-title">VHF Radio Simulator</div>
      <div class="vhf-desc">
        Practice VHF radio calls with an AI-powered simulator. Push-to-talk voice interaction, realistic audio effects, and guided scenarios for Mayday, Pan-Pan, Securité, and routine calls.
      </div>
      <a href="/tools/vhf" class="vhf-launch-btn">Launch Simulator →</a>
      <div class="vhf-features">
        <div class="vhf-feature">
          <div class="vhf-feature-label">Voice-first</div>
          <div class="vhf-feature-val">Push-to-talk with speech recognition</div>
        </div>
        <div class="vhf-feature">
          <div class="vhf-feature-label">AI stations</div>
          <div class="vhf-feature-val">Coastguard, vessels, marinas respond with correct protocol</div>
        </div>
        <div class="vhf-feature">
          <div class="vhf-feature-label">6 regions</div>
          <div class="vhf-feature-val">UK, Caribbean, Mediterranean, SE Asia, Pacific, Canaries</div>
        </div>
        <div class="vhf-feature">
          <div class="vhf-feature-label">RYA exam prep</div>
          <div class="vhf-feature-val">Guided scenarios with real-time feedback and scoring</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .vhf-placeholder {
    flex: 1;
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-y: auto;
  }

  .vhf-placeholder-content {
    max-width: 440px;
    padding: 40px 32px;
    text-align: center;
  }

  .vhf-radio-icon {
    color: var(--ink-light);
    margin-bottom: 20px;
  }

  .vhf-title {
    font-family: 'Space Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .vhf-desc {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(0,0,0,0.45);
    margin-bottom: 28px;
  }

  .vhf-features {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .vhf-feature {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .vhf-feature:last-child { border-bottom: none; }

  .vhf-feature-label {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    font-weight: 500;
    color: var(--ink);
    flex-shrink: 0;
    min-width: 100px;
  }

  .vhf-feature-val {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: rgba(0,0,0,0.4);
    text-align: right;
  }

  .vhf-launch-btn {
    display: inline-block;
    margin-bottom: 24px;
    padding: 10px 24px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: var(--accent-green, #4ade80);
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .vhf-launch-btn:hover { opacity: 0.85; }
</style>
