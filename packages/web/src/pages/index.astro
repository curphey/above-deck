---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Above Deck — The Sailing Platform for Modern Cruisers">
  <main class="landing">

    <!-- Hero -->
    <section class="hero">
      <h1 class="hero-title">Plan your energy system.<br />Learn from the community.</h1>
      <p class="hero-subtitle">
        Above Deck is an open-source set of tools and shared knowledge for cruising sailors.
        Size your solar and battery setup, learn from real-world experience, and connect with
        people who actually live aboard.
      </p>
      <a href="/tools/solar" class="cta-button">Open Energy Planner</a>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="features-grid">

        <a href="/tools/solar" class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2a4 4 0 1 0 8 0" /><path d="M12 2v6" /><path d="M4.6 9l5.2 3" /><path d="M19.4 9l-5.2 3" /><path d="M3 17h3l2 4" /><path d="M21 17h-3l-2 4" /><path d="M12 12v10" />
            </svg>
          </div>
          <h2 class="feature-title">Energy Planner</h2>
          <p class="feature-desc">
            Size your solar array, spec your battery bank, and build a realistic power budget.
            Based on real consumption data and location-specific irradiance.
          </p>
        </a>

        <a href="/knowledge" class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6v13" /><path d="M12 6v13" /><path d="M21 6v13" />
            </svg>
          </div>
          <h2 class="feature-title">Knowledge Base</h2>
          <p class="feature-desc">
            Practical guides written by experienced cruisers. Electrical systems, watermakers,
            passage planning — no fluff, just what you need to know.
          </p>
        </a>

        <a href="/community" class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 7m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /><path d="M21 21v-2a4 4 0 0 0 -3 -3.85" />
            </svg>
          </div>
          <h2 class="feature-title">Community</h2>
          <p class="feature-desc">
            Connect with other sailors, share your setup and experiences, and get answers
            from people who have been there.
          </p>
        </a>

      </div>
    </section>

    <!-- Blog -->
    <section class="blog-section">
      <h2 class="section-title">Latest Posts</h2>
      <p class="blog-placeholder">Check back soon — we are working on the first articles.</p>
    </section>

  </main>
</BaseLayout>

<style>
  :root {
    --bg-dark: #1a1a2e;
    --surface: #16213e;
    --bg-light: #f5f5f0;
    --text-dark: #e0e0e0;
    --text-light: #2d2d3a;
    --text-secondary: #8b8b9e;
    --accent-green: #4ade80;
    --accent-coral: #f87171;
    --accent-blue: #60a5fa;
    --grid: #2d2d4a;
  }

  .landing {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--grid);
  }

  .hero-title {
    font-family: 'Space Mono', monospace;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-dark);
    margin: 0 0 1.25rem;
  }

  .hero-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 0 2rem;
  }

  .cta-button {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--bg-dark);
    background: var(--accent-green);
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--accent-green);
    transition: background 0.15s, color 0.15s;
  }

  .cta-button:hover {
    background: transparent;
    color: var(--accent-green);
  }

  /* Features */
  .features {
    padding: 3rem 0;
    border-bottom: 1px solid var(--grid);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--grid);
    padding: 1.5rem;
    transition: border-color 0.15s;
  }

  .feature-card:hover {
    border-color: var(--accent-blue);
  }

  .feature-icon {
    color: var(--accent-blue);
    margin-bottom: 1rem;
  }

  .feature-title {
    font-family: 'Space Mono', monospace;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 0.75rem;
  }

  .feature-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Blog */
  .blog-section {
    padding: 3rem 0 4rem;
  }

  .section-title {
    font-family: 'Space Mono', monospace;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 1rem;
  }

  .blog-placeholder {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Light mode overrides */
  [data-mantine-color-scheme="light"] .hero-title,
  [data-mantine-color-scheme="light"] .feature-title,
  [data-mantine-color-scheme="light"] .section-title {
    color: var(--text-light);
  }

  [data-mantine-color-scheme="light"] .cta-button {
    color: var(--bg-light);
    background: #16a34a;
    border-color: #16a34a;
  }

  [data-mantine-color-scheme="light"] .cta-button:hover {
    background: transparent;
    color: #16a34a;
  }

  [data-mantine-color-scheme="light"] .feature-card {
    border-color: #d4d4d4;
  }

  [data-mantine-color-scheme="light"] .hero {
    border-bottom-color: #d4d4d4;
  }

  [data-mantine-color-scheme="light"] .features {
    border-bottom-color: #d4d4d4;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 3rem 0 2rem;
    }
  }

  @media (max-width: 480px) {
    .landing {
      padding: 0 1rem;
    }
  }
</style>
