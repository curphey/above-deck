---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { createSupabaseServerClient } from '../../lib/supabase-server';
export const prerender = false;

const { slug } = Astro.params;
const supabase = createSupabaseServerClient(Astro.cookies);
const { data: post } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('published', true)
  .single();

if (!post) return Astro.redirect('/blog');

const siteUrl = 'https://abovedeck.io';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.published_at,
  dateModified: post.updated_at ?? post.published_at,
  ...(post.hero_image ? { image: post.hero_image } : {}),
  author: {
    '@type': 'Person',
    name: post.author_name ?? 'Above Deck',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Above Deck',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/blog/${slug}`,
  },
};

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function categoryLabel(cat: string): string {
  const labels: Record<string, string> = {
    builder: "Builder's Journal",
    sailing: 'Sailing',
    electrical: 'Electrical',
    destinations: 'Destinations',
  };
  return labels[cat] ?? cat;
}
---
<BaseLayout
  title={`${post.title} — Above Deck`}
  description={post.description}
  image={post.hero_image}
  type="article"
>
  <JsonLd schema={articleSchema} />
  <article class="blog-post">
    <header>
      <div class="meta">
        <span class="category">{categoryLabel(post.category)}</span>
        <span class="date">{formatDate(post.published_at)}</span>
      </div>
      <h1>{post.title}</h1>
      <p class="description">{post.description}</p>
      {post.tags && post.tags.length > 0 && (
        <div class="tags">
          {post.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="content" set:html={post.body} />

    <footer>
      <a href="/blog" class="back-link">&larr; All posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #2d2d4a;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
  }

  .category {
    color: #4ade80;
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .date {
    color: #8b8b9e;
  }

  h1 {
    font-family: 'Space Mono', monospace;
    font-size: 1.75rem;
    line-height: 1.3;
    margin: 0 0 0.75rem;
  }

  .description {
    color: #8b8b9e;
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    color: #60a5fa;
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid #2d2d4a;
    border-radius: 4px;
  }

  .content {
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .content :global(h2) {
    font-family: 'Space Mono', monospace;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #e0e0e0;
  }

  .content :global(p) {
    margin: 0 0 1rem;
    color: #ccc;
  }

  .content :global(strong) {
    color: #e0e0e0;
  }

  .content :global(a) {
    color: #60a5fa;
    text-decoration: none;
  }

  .content :global(a:hover) {
    text-decoration: underline;
  }

  .content :global(ul), .content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
    color: #ccc;
  }

  .content :global(li) {
    margin-bottom: 0.25rem;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .content :global(th), .content :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid #2d2d4a;
    text-align: left;
  }

  .content :global(th) {
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    color: #8b8b9e;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .content :global(code) {
    font-family: 'Fira Code', monospace;
    font-size: 0.85rem;
    background: #16213e;
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
  }

  footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #2d2d4a;
  }

  .back-link {
    color: #60a5fa;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
