---
// MFDLayout.astro — Wraps tool pages in the MFD device frame
// All tools render inside this layout to maintain the unified MFD experience.
import DeviceFrame from '../components/mfd/DeviceFrame.astro';
import TopBar from '../components/mfd/TopBar.astro';
import { NavBar } from '../components/mfd/NavBar';
import '../components/mfd/landing.css';

interface Props {
  title: string;
  description?: string;
  screenId: string;
}

const { title, description = 'The sailing platform for modern cruisers', screenId } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-default.png', Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <meta name="theme-color" content="#1a1a2e" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Above Deck" />
  <link rel="apple-touch-icon" href="/icon.svg" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
</head>
<body>
  <DeviceFrame>
    <TopBar />
    <div class="screen active" id={`screen-${screenId}`}>
      <slot />
    </div>
    <NavBar client:load />
  </DeviceFrame>
</body>
</html>
