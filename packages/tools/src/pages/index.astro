---
import MFDLayout from '../layouts/MFDLayout.astro';
export const prerender = false;
---
<MFDLayout title="Above Deck Tools" screenId="home">
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 24px; gap: 16px;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; width: 100%; max-width: 640px;">
      <a href="/tools/solar" style="text-decoration: none;" class="tool-card">
        <div class="tool-icon">☀</div>
        <div class="tool-name">Solar Planner</div>
        <div class="tool-desc">Size your solar system for any cruising ground</div>
      </a>
      <a href="/tools/vhf" style="text-decoration: none;" class="tool-card">
        <div class="tool-icon">📻</div>
        <div class="tool-name">VHF Radio</div>
        <div class="tool-desc">Practice radio procedure with AI coastguard agents</div>
      </a>
      <a href="/tools/chart" style="text-decoration: none;" class="tool-card">
        <div class="tool-icon">◈</div>
        <div class="tool-name">Chartplotter</div>
        <div class="tool-desc">Live nautical chart with AIS vessel tracking</div>
      </a>
    </div>
  </div>
</MFDLayout>

<style>
  .tool-card {
    background: #16213e;
    border: 1px solid #2d2d4a;
    border-radius: 6px;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    transition: border-color 0.15s, background 0.15s;
    cursor: pointer;
  }
  .tool-card:hover {
    border-color: #60a5fa;
    background: #1a2744;
  }
  .tool-icon {
    font-size: 28px;
    line-height: 1;
  }
  .tool-name {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: #e0e0e0;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
  .tool-desc {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #8b8b9e;
    line-height: 1.4;
  }
</style>
