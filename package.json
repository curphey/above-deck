{
  "name": "above-deck",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @above-deck/site dev",
    "dev:tools": "pnpm --filter @above-deck/tools dev",
    "build": "pnpm --filter @above-deck/site build && pnpm --filter @above-deck/tools build",
    "build:site": "pnpm --filter @above-deck/site build",
    "build:tools": "pnpm --filter @above-deck/tools build",
    "test": "pnpm --filter @above-deck/site test && pnpm --filter @above-deck/tools test",
    "test:site": "pnpm --filter @above-deck/site test",
    "test:tools": "pnpm --filter @above-deck/tools test",
    "test:e2e": "pnpm --filter @above-deck/site test:e2e"
  }
}
